# Cache Settings
prefer-offline=true
cache-min=9999999

# Peer Dependency Handling
legacy-peer-deps=true

# Package Lock
package-lock=true

# Performance
fund=false
audit=false
progress=false

# Registry (use faster mirror if needed)
registry=https://registry.npmjs.org/

# Max connections for faster downloads
maxsockets=20

# Strict SSL (set to false if having SSL issues)
strict-ssl=true

# Log level (minimal for speed)
loglevel=error